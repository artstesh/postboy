{
  "name": "@artstesh/postboy",
  "version": "1.4.0",
  "author": "artstesh",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "license": "MIT",
  "description": "Let's send a message ;)",
  "homepage": "https://postboy.artstesh.ru",
  "sideEffects": false,
  "keywords": [
    "pubsub",
    "event-bus",
    "typescript",
    "rxjs",
    "typed",
    "framework-agnostic",
    "cqrs",
    "messaging",
    "middleware",
    "lifecycle-management"
  ],
  "scripts": {
    "pack:check": "npm pack --dry-run",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build && npm run pack:check",
    "preversion": "npm run lint && npm run typecheck && npm test",
    "analyze": "esbuild lib/index.mjs --bundle --outfile=./stats/out.js --metafile=./stats/meta.json && npx esbuild-visualizer --filename=./stats/stats.html --metadata ./stats/meta.json",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --tags",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "test": "jest --config jest.config.js",
    "build": "tsup",
    "clean": "rimraf --glob lib/ src/**/*.js src/**/*.js.map src/**/*.d.ts src/**/*.d.ts.map"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.cjs",
      "default": "./lib/index.mjs"
    }
  },
  "files": [
    "lib/**/*"
  ],
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/artstesh/postboy.git"
  },
  "bugs": {
    "url": "https://github.com/artstesh/postboy/issues"
  },
  "peerDependencies": {
    "rxjs": "^6.0.0"
  },
  "devDependencies": {
    "@artstesh/forger": "^1.2.1",
    "@artstesh/it-should": "^1.2.0",
    "@eslint/js": "^10.0.1",
    "@types/jest": "29.5.12",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "esbuild-visualizer": "^0.7.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "jest": "29.7.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "rxjs": "^7.0.0",
    "source-map-explorer": "^2.5.3",
    "ts-jest": "29.1.2",
    "ts-mockito": "^2.6.1",
    "tsup": "^8.5.1",
    "typescript": "^4.3.5",
    "typescript-eslint": "^8.59.2"
  }
}
