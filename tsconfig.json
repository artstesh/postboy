{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./lib",
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "declaration": true,
    "forceConsistentCasingInFileNames": true,
    "module": "commonjs",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "pretty": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2020",
    "lib": ["ES2020"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true
  },
  "exclude": [
    "node_modules",
    "**/*.spec.ts"
  ],
  "include": ["src/**/*.ts"]
}
